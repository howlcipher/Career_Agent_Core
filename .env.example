# Copy to .env and fill in your values. NEVER commit .env itself.

# ── LLM provider ─────────────────────────────────────────────────────
# ollama (default, local, free) | claude | gemini
LLM_PROVIDER="ollama"

# Ollama (local) — models used by the agent.
# Defaults if unset: llama3.1 / llava / nomic-embed-text (fits ~8-16 GB RAM).
# Recommended on 32 GB RAM machines (better writing, ~5s scoring on CPU):
OLLAMA_MODEL="qwen3:30b-instruct"
OLLAMA_VISION_MODEL="qwen2.5vl:7b"
OLLAMA_EMBED_MODEL="nomic-embed-text"
# OLLAMA_HOST="http://localhost:11434"

# Claude (only if LLM_PROVIDER=claude; embeddings still use Ollama)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-8"

# Gemini (only if LLM_PROVIDER=gemini)
# GEMINI_API_KEY="your_api_key_here"
# GEMINI_MODEL="gemini-flash-latest"

# ── Scraping & mail tracking ─────────────────────────────────────────
SERPAPI_API_KEY="your_serpapi_key"
IMAP_SERVER="imap.gmail.com:993"
IMAP_USER="your_email@gmail.com"
IMAP_APP_PASSWORD="your_16_digit_app_password"
